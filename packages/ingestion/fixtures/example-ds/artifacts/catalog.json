{
  "components": {
    "PageShell": {
      "description": "The layout-owning page shell. Every screen starts from a shell; renders a titled header above a main content region. Put page content in its children.",
      "slots": ["default"],
      "props": {
        "type": "object",
        "properties": { "title": { "type": "string" } },
        "required": ["title"],
        "additionalProperties": false
      }
    },
    "Stack": {
      "description": "A flex layout container that stacks its children vertically (default) or horizontally with a spacing-token gap. Use for arranging components.",
      "slots": ["default"],
      "props": {
        "type": "object",
        "properties": {
          "direction": { "type": ["string", "null"], "enum": ["vertical", "horizontal", null] },
          "gap": { "type": ["string", "null"], "enum": ["1", "2", "4", "6", "8", null] }
        },
        "required": ["direction", "gap"],
        "additionalProperties": false
      }
    },
    "Card": {
      "description": "A surface container with optional title, border, radius and shadow. Use to group related content.",
      "slots": ["default"],
      "props": {
        "type": "object",
        "properties": { "title": { "type": ["string", "null"] } },
        "required": ["title"],
        "additionalProperties": false
      }
    },
    "Text": {
      "description": "A paragraph of text at one of the type-scale sizes. Use for body copy and labels.",
      "slots": [],
      "props": {
        "type": "object",
        "properties": {
          "content": { "type": "string" },
          "size": { "type": ["string", "null"], "enum": ["sm", "md", "lg", "xl", null] }
        },
        "required": ["content", "size"],
        "additionalProperties": false
      }
    },
    "Button": {
      "description": "A clickable button in a primary or secondary variant.",
      "slots": [],
      "props": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "variant": { "type": ["string", "null"], "enum": ["primary", "secondary", null] }
        },
        "required": ["label", "variant"],
        "additionalProperties": false
      }
    }
  }
}
