{
  "$description": "Semantic tokens — the themeable surface. Components reference ONLY these (never raw primitives). Re-point these aliases (or swap the primitives) and the whole system re-themes. Light theme.",
  "background": {
    "$type": "color",
    "canvas": { "$value": "{color.white}" },
    "subtle": { "$value": "{color.neutral.50}" },
    "muted": { "$value": "{color.neutral.100}" },
    "emphasis": { "$value": "{color.neutral.900}" },
    "overlay": { "$value": "rgb(0 0 0 / 0.5)" }
  },
  "foreground": {
    "$type": "color",
    "default": { "$value": "{color.neutral.900}" },
    "muted": { "$value": "{color.neutral.500}" },
    "subtle": { "$value": "{color.neutral.400}" },
    "onEmphasis": { "$value": "{color.white}" }
  },
  "border": {
    "$type": "color",
    "default": { "$value": "{color.neutral.200}" },
    "strong": { "$value": "{color.neutral.300}" },
    "subtle": { "$value": "{color.neutral.100}" }
  },
  "input": { "$type": "color", "border": { "$value": "{color.neutral.300}" } },
  "ring": { "$type": "color", "default": { "$value": "{color.blue.500}" } },
  "primary": {
    "$type": "color",
    "default": { "$value": "{color.blue.600}" },
    "hover": { "$value": "{color.blue.700}" },
    "active": { "$value": "{color.blue.800}" },
    "subtle": { "$value": "{color.blue.50}" },
    "foreground": { "$value": "{color.white}" }
  },
  "secondary": {
    "$type": "color",
    "default": { "$value": "{color.neutral.100}" },
    "hover": { "$value": "{color.neutral.200}" },
    "active": { "$value": "{color.neutral.300}" },
    "foreground": { "$value": "{color.neutral.900}" }
  },
  "accent": {
    "$type": "color",
    "default": { "$value": "{color.violet.600}" },
    "hover": { "$value": "{color.violet.700}" },
    "subtle": { "$value": "{color.violet.50}" },
    "foreground": { "$value": "{color.white}" }
  },
  "muted": {
    "$type": "color",
    "default": { "$value": "{color.neutral.100}" },
    "foreground": { "$value": "{color.neutral.500}" }
  },
  "destructive": {
    "$type": "color",
    "default": { "$value": "{color.red.600}" },
    "hover": { "$value": "{color.red.700}" },
    "subtle": { "$value": "{color.red.50}" },
    "foreground": { "$value": "{color.white}" }
  },
  "success": {
    "$type": "color",
    "default": { "$value": "{color.green.600}" },
    "subtle": { "$value": "{color.green.50}" },
    "foreground": { "$value": "{color.white}" }
  },
  "warning": {
    "$type": "color",
    "default": { "$value": "{color.amber.500}" },
    "subtle": { "$value": "{color.amber.50}" },
    "foreground": { "$value": "{color.neutral.900}" }
  },
  "info": {
    "$type": "color",
    "default": { "$value": "{color.sky.500}" },
    "subtle": { "$value": "{color.sky.50}" },
    "foreground": { "$value": "{color.white}" }
  },
  "card": {
    "$type": "color",
    "background": { "$value": "{color.white}" },
    "foreground": { "$value": "{color.neutral.900}" }
  },
  "popover": {
    "$type": "color",
    "background": { "$value": "{color.white}" },
    "foreground": { "$value": "{color.neutral.900}" }
  },
  "radius": {
    "$type": "dimension",
    "default": { "$value": "{radius.md}" },
    "control": { "$value": "{radius.md}" },
    "card": { "$value": "{radius.xl}" }
  },
  "text": {
    "$type": "typography",
    "display": {
      "$value": {
        "fontFamily": "{fontFamily.sans}",
        "fontSize": "{fontSize.5xl}",
        "fontWeight": "{fontWeight.bold}",
        "lineHeight": "{lineHeight.tight}",
        "letterSpacing": "{letterSpacing.tight}"
      }
    },
    "heading": {
      "$value": {
        "fontFamily": "{fontFamily.sans}",
        "fontSize": "{fontSize.2xl}",
        "fontWeight": "{fontWeight.semibold}",
        "lineHeight": "{lineHeight.snug}",
        "letterSpacing": "{letterSpacing.tight}"
      }
    },
    "title": {
      "$value": {
        "fontFamily": "{fontFamily.sans}",
        "fontSize": "{fontSize.lg}",
        "fontWeight": "{fontWeight.semibold}",
        "lineHeight": "{lineHeight.snug}",
        "letterSpacing": "{letterSpacing.normal}"
      }
    },
    "body": {
      "$value": {
        "fontFamily": "{fontFamily.sans}",
        "fontSize": "{fontSize.md}",
        "fontWeight": "{fontWeight.normal}",
        "lineHeight": "{lineHeight.normal}",
        "letterSpacing": "{letterSpacing.normal}"
      }
    },
    "small": {
      "$value": {
        "fontFamily": "{fontFamily.sans}",
        "fontSize": "{fontSize.sm}",
        "fontWeight": "{fontWeight.normal}",
        "lineHeight": "{lineHeight.normal}",
        "letterSpacing": "{letterSpacing.normal}"
      }
    },
    "code": {
      "$value": {
        "fontFamily": "{fontFamily.mono}",
        "fontSize": "{fontSize.sm}",
        "fontWeight": "{fontWeight.normal}",
        "lineHeight": "{lineHeight.normal}",
        "letterSpacing": "{letterSpacing.normal}"
      }
    }
  }
}
